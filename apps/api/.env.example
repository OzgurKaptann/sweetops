# ── SweetOps API configuration example ───────────────────────────────────────
# Copy to `apps/api/.env` and adjust. `.env` is git-ignored; only `.env.example`
# is tracked. Every value below is a LOCAL DEVELOPMENT PLACEHOLDER — never commit
# a real secret to this repository.
#
# Every variable here maps to a field on `Settings` in app/core/config.py; there
# are no undocumented settings and no separate SECRET_KEY/SESSION_SECRET (session
# and CSRF tokens are random per session and stored only as SHA-256 hashes — see
# docs/STAFF_AUTH_RBAC.md).
#
# The repo-root .env.example describes the Docker Compose stack and the frontend
# variables. See docs/PRODUCTION_READINESS.md for the full checklist.

# Environment: "development" | "production".
# In production, Secure cookies are forced on regardless of SESSION_COOKIE_SECURE.
ENVIRONMENT=development

# Business timezone — an IANA zone name. Affects REPORTING ONLY: where a business
# day starts and ends, daily/hourly buckets, "today", and the 7/30-day windows.
# Storage is unchanged and stays UTC everywhere. Set this to the shop's actual
# zone; an unknown name fails at startup rather than silently reverting to UTC.
# See apps/api/app/core/business_time.py.
BUSINESS_TIMEZONE=Europe/Istanbul

# Database / cache
DATABASE_URL=postgresql://sweetops:sweetops_password@localhost:5432/sweetops_db
REDIS_URL=redis://localhost:6379/0

# Public customer web base URL (used by scripts/manage_qr_tokens.py when printing
# the customer URL encoded in a table QR code).
#
# NOTE: `npm run dev:customer` serves customer-web on port 3001 (see package.json
# and README section 4). The compiled-in default in app/core/config.py is still
# :3000, so set this explicitly or the printed QR URLs point at a port where
# nothing is listening. Tracked in docs/PRODUCTION_READINESS.md.
CUSTOMER_WEB_BASE_URL=http://localhost:3001

# Transition flag only — production MUST leave this false so client-supplied
# store/table context is never trusted (secure QR path is the only accepted one).
ALLOW_LEGACY_ORDER_CONTEXT=false

# ── Staff session cookies ────────────────────────────────────────────────────
SESSION_COOKIE_NAME=sweetops_session
CSRF_COOKIE_NAME=sweetops_csrf
SESSION_COOKIE_PATH=/
# Leave empty for a host-only cookie (recommended). Never assume a wildcard parent domain.
SESSION_COOKIE_DOMAIN=
# "lax" | "strict" | "none"
SESSION_COOKIE_SAMESITE=lax
# Development only. In production this is forced true.
SESSION_COOKIE_SECURE=false

# ── Session lifetime ─────────────────────────────────────────────────────────
SESSION_ABSOLUTE_LIFETIME_HOURS=12
SESSION_IDLE_TIMEOUT_MINUTES=120
SESSION_LAST_SEEN_THROTTLE_SECONDS=300

# ── Login protection ─────────────────────────────────────────────────────────
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Password policy ──────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=10
PASSWORD_MAX_LENGTH=1024

# ── Trusted origins (cookie auth requires an explicit, credentialed allow-list) ──
# Comma-separated EXACT origins (scheme + host + port, no trailing slash, no
# wildcards). NEVER use "*" with credentials. These drive three things at once:
# the CORS allow-list, the origin check on state-changing staff requests, and the
# kitchen WebSocket handshake check.
#
# Staff surfaces — kitchen-web 3002, owner-web 3003, cashier-web 3004. Port 3001
# (customer-web) is included to match the compiled-in default in config.py.
STAFF_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3002,http://localhost:3003,http://localhost:3004
# Public customer surface. customer-web runs on 3001 under `npm run dev:customer`;
# the compiled-in default is still :3000, so set this explicitly.
PUBLIC_TRUSTED_ORIGINS=http://localhost:3001

# ── WebSocket Origin (Cross-Site WebSocket Hijacking defence) ────────────────
# The kitchen WebSocket handshake validates the browser Origin against
# STAFF_TRUSTED_ORIGINS (exact scheme/host/port). Browsers always send Origin on
# a WS handshake, so a missing Origin means a non-browser client. Production MUST
# reject missing Origin — leave this false. Set true ONLY in an isolated
# test/dev configuration for non-browser clients (CLI, server-to-server).
ALLOW_MISSING_WEBSOCKET_ORIGIN=false

# NOTE: Application-level login lockout is NOT a substitute for infrastructure
# rate limiting. Put a reverse proxy / API gateway rate limiter in front of
# /auth/login in production.
