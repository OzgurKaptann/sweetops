# ── SweetOps API configuration example ───────────────────────────────────────
# Copy to .env and adjust. Never commit real secrets.

# Environment: "development" | "production".
# In production, Secure cookies are forced on regardless of SESSION_COOKIE_SECURE.
ENVIRONMENT=development

# Database / cache
DATABASE_URL=postgresql://sweetops:sweetops_password@localhost:5432/sweetops_db
REDIS_URL=redis://localhost:6379/0

# Public customer web base URL (used for printing QR URLs from the CLI).
CUSTOMER_WEB_BASE_URL=http://localhost:3000

# Transition flag only — production MUST leave this false so client-supplied
# store/table context is never trusted (secure QR path is the only accepted one).
ALLOW_LEGACY_ORDER_CONTEXT=false

# ── Staff session cookies ────────────────────────────────────────────────────
SESSION_COOKIE_NAME=sweetops_session
CSRF_COOKIE_NAME=sweetops_csrf
SESSION_COOKIE_PATH=/
# Leave empty for a host-only cookie (recommended). Never assume a wildcard parent domain.
SESSION_COOKIE_DOMAIN=
# "lax" | "strict" | "none"
SESSION_COOKIE_SAMESITE=lax
# Development only. In production this is forced true.
SESSION_COOKIE_SECURE=false

# ── Session lifetime ─────────────────────────────────────────────────────────
SESSION_ABSOLUTE_LIFETIME_HOURS=12
SESSION_IDLE_TIMEOUT_MINUTES=120
SESSION_LAST_SEEN_THROTTLE_SECONDS=300

# ── Login protection ─────────────────────────────────────────────────────────
LOGIN_MAX_FAILED_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15

# ── Password policy ──────────────────────────────────────────────────────────
PASSWORD_MIN_LENGTH=10
PASSWORD_MAX_LENGTH=1024

# ── Trusted origins (cookie auth requires an explicit, credentialed allow-list) ──
# Comma-separated exact origins. NEVER use "*" with credentials.
# owner-web + kitchen-web dev origins:
STAFF_TRUSTED_ORIGINS=http://localhost:3001,http://localhost:3002
# public customer web origin(s):
PUBLIC_TRUSTED_ORIGINS=http://localhost:3000

# ── WebSocket Origin (Cross-Site WebSocket Hijacking defence) ────────────────
# The kitchen WebSocket handshake validates the browser Origin against
# STAFF_TRUSTED_ORIGINS (exact scheme/host/port). Browsers always send Origin on
# a WS handshake, so a missing Origin means a non-browser client. Production MUST
# reject missing Origin — leave this false. Set true ONLY in an isolated
# test/dev configuration for non-browser clients (CLI, server-to-server).
ALLOW_MISSING_WEBSOCKET_ORIGIN=false

# NOTE: Application-level login lockout is NOT a substitute for infrastructure
# rate limiting. Put a reverse proxy / API gateway rate limiter in front of
# /auth/login in production.
